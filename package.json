{
  "name": "mappersguild",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "prod": "cross-env NODE_ENV=production node ./dist/api/app.js",
    "build-src": "vite build",
    "build-app": "cross-env NODE_ENV=production tsc --project api/tsconfig.json",
    "dev": "run-p -rl watch-app watch-src",
    "watch-app": "tsx watch --tsconfig api/tsconfig.json api/app.ts",
    "watch-src": "vite",
    "serve": "vite preview",
    "lint": "eslint .",
    "tsc": "tsc --noEmit true --project api/tsconfig.json"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@popperjs/core": "^2.9.3",
    "@types/node-fetch": "^2.6.6",
    "axios": "^1.13.5",
    "bootstrap": "^5.3.8",
    "connect-mongo": "^6.0.0",
    "cookie-parser": "^1.4.5",
    "cross-env": "^7.0.3",
    "eslint-config-prettier": "^8.5.0",
    "express": "^4.17.1",
    "express-async-errors": "^3.1.1",
    "express-session": "^1.17.2",
    "markdown-it": "^14.1.1",
    "mongoose": "^9.2.1",
    "morgan": "^1.10.0",
    "node-cron": "^2.0.3",
    "node-fetch": "^2.7.0",
    "shopify-buy": "^2.21.1",
    "vue": "^3.2.4",
    "vue-router": "^4.0.11",
    "vuex": "^4.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/bootstrap": "^5.2.10",
    "@types/express": "^4.17.13",
    "@types/express-session": "^1.17.4",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/compiler-sfc": "^3.2.4",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^17.3.0",
    "npm-run-all2": "^8.0.4",
    "sass": "^1.38.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.3.1",
    "vue-tsc": "^0.2.3"
  }
}
